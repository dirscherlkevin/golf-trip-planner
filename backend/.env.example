# Frontend base URL — used in invite links and email trip URLs
APP_BASE_URL=http://localhost:5173

# PostgreSQL connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/golf_trip_planner
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/golf_trip_planner_test

# JWT signing key — change this in production
SECRET_KEY=dev-secret-key-change-in-production

# Anthropic API key for AI destination/course/lodging generation
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_REAL_KEY

# SMTP — leave blank to skip sending (emails still queue in DB)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=Golf Trip Planner <noreply@golftrip.app>
